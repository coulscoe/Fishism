	rename -uid "F5B335DA-48D3-2B77-9604-FDB3CBE08050";
	setAttr ".ufem" -type "stringArray" 0  ;
createNode renderLayerManager -n "renderLayerManager";
	rename -uid "47848BA8-43C4-D60A-4144-FEA77349C506";
createNode renderLayer -n "defaultRenderLayer";
	rename -uid "0B4D51FF-4D96-9A70-5DF1-B1B9A48AEDA9";
